# Application
APP_ENV=development
APP_NAME=agente-citas-backend
APP_DEBUG=true
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Database
DATABASE_URL=postgresql+asyncpg://agente:agente_dev@localhost:5432/agente_citas

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=60

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL_REASONING=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=500
ANTHROPIC_TEMPERATURE=0.3

# OpenAI (Whisper for audio transcription)
OPENAI_API_KEY=sk-xxxxx
OPENAI_WHISPER_MODEL=whisper-1

# Voyage AI (embeddings for RAG)
VOYAGE_API_KEY=pa-xxxxx
VOYAGE_EMBEDDING_MODEL=voyage-multilingual-2

# WhatsApp Cloud API (Meta)
WHATSAPP_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=50

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Observability
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Security
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
