[project]
name = "agente-citas-backend"
version = "0.1.0"
description = "WhatsApp appointment scheduling agent — FastAPI backend with DDD architecture"
requires-python = ">=3.12"
readme = "../README.md"

dependencies = [
    # Web framework
    "fastapi[standard]>=0.115.0",
    "uvicorn[standard]>=0.32.0",
    "python-multipart>=0.0.12",

    # Validation
    "pydantic>=2.9.0",
    "pydantic-settings>=2.6.0",

    # Database
    "sqlalchemy[asyncio]>=2.0.36",
    "asyncpg>=0.30.0",
    "alembic>=1.14.0",
    "pgvector>=0.3.6",

    # Cache & queues
    "redis>=5.2.0",
    "arq>=0.26.3",

    # AI / LLM
    #"anthropic>=0.39.0",
    #"langgraph>=0.2.50",
    #"voyageai>=0.3.2",
    #"openai>=1.54.0",  # for Whisper

    # ML
    "scikit-learn>=1.5.0",
    "lightgbm>=4.5.0",
    "numpy>=2.1.0",
    "pandas>=2.2.0",

    # HTTP client
    "httpx>=0.28.0",

    # Date / time
    "python-dateutil>=2.9.0",
    "babel>=2.16.0",

    # Logging & observability
    "structlog>=24.4.0",
    "sentry-sdk[fastapi]>=2.18.0",

    # Utilities
    "tenacity>=9.0.0",
    "phonenumbers>=8.13.0",
]

[dependency-groups]
dev = [
    "pytest>=8.3.0",
    "pytest-asyncio>=0.24.0",
    "pytest-cov>=6.0.0",
    "pytest-mock>=3.14.0",
    "httpx>=0.28.0",
    "ruff>=0.7.0",
    "mypy>=1.13.0",
    "pre-commit>=4.0.0",
    "factory-boy>=3.3.0",
    "faker>=33.0.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src"]

[tool.ruff]
target-version = "py312"
line-length = 100
src = ["src", "tests"]

[tool.ruff.lint]
select = [
    "E",   # pycodestyle errors
    "W",   # pycodestyle warnings
    "F",   # pyflakes
    "I",   # isort
    "B",   # flake8-bugbear
    "C4",  # flake8-comprehensions
    "UP",  # pyupgrade
    "N",   # pep8-naming
    "SIM", # flake8-simplify
    "RUF", # ruff-specific
    "TCH", # flake8-type-checking
]
ignore = ["E501"]  # line too long (handled by formatter)

[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = ["B011", "N802"]

[tool.mypy]
python_version = "3.12"
strict = true
warn_return_any = true
warn_unused_configs = true
plugins = ["pydantic.mypy"]

[[tool.mypy.overrides]]
module = ["langgraph.*", "voyageai.*", "lightgbm.*"]
ignore_missing_imports = true

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
python_files = ["test_*.py"]
addopts = [
    "-ra",
    "--strict-markers",
    "--strict-config",
    "--cov=src",
    "--cov-report=term-missing",
]
markers = [
    "unit: unit tests (fast, isolated)",
    "integration: integration tests (require DB/Redis)",
    "e2e: end-to-end tests (require full stack)",
]
